# Optional defaults for record-window-video.sh

# Where generated videos should be saved when no explicit output path is passed.
OW_WINDOW_RECORDER_OUT_DIR=artifacts/videos

# Default recording duration in seconds.
OW_WINDOW_RECORDER_DURATION=45

# Default frame rate.
OW_WINDOW_RECORDER_FPS=30

# Show mouse cursor in recordings (1=true, 0=false).
OW_WINDOW_RECORDER_SHOW_CURSOR=1
